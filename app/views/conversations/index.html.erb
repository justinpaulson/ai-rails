<div class="flex-1 flex items-center justify-center bg-gray-900">
  <div class="max-w-lg w-full px-6">
    <div class="text-center mb-8">
      <h2 class="text-2xl font-bold text-white mb-2">AI Rails</h2>
      <p class="text-gray-400">Start a conversation with Claude Code</p>
    </div>

    <%= form_with model: @conversation, url: conversations_path, method: :post, class: "space-y-4" do |f| %>
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1">Working Directory</label>
        <%= f.text_field :working_directory,
                          value: @conversation.working_directory,
                          class: "w-full px-4 py-3 bg-gray-800 border border-gray-600 text-white placeholder-gray-400 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent font-mono text-sm",
                          placeholder: "~/Developer/my-project" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1">Message</label>
        <%= text_area_tag :prompt,
                          nil,
                          rows: 3,
                          class: "w-full px-4 py-3 bg-gray-800 border border-gray-600 text-white placeholder-gray-400 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none",
                          placeholder: "What would you like Claude to help with?" %>
      </div>

      <button type="submit"
              class="w-full px-4 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-gray-900 transition-colors font-medium">
        Start Conversation
      </button>
    <% end %>
  </div>
</div>
